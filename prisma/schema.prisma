// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
  projects Project[]
}

model Tech {
  id   Int    @id @default(autoincrement())
  name String @unique
  projects Project[]
}

model Image {
  id  Int    @id @default(autoincrement())
  url String
  project    Project  @relation(fields: [projectId], references: [id])
  projectId  Int
}

model Project {
  id            Int             @id @default(autoincrement())
  name          String          @unique
  categories    Category[]
  stack         Tech[]
  description   String?
  objectives    String?
  achieved      String?
  todo          String?
  images        Image[]
  repositoryUrl String
  // firstCommit   DateTime
  // lastCommit    DateTime
  visible       Boolean         @default(true)
}
